# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: Optional. Defines the model to use from OpenRouter.
# Defaults to "meta-llama/llama-3-8b-instruct:free" if not specified.
OPENROUTER_MODEL="meta-llama/llama-3-8b-instruct:free"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: Set this if your frontend requests are served from a separate hosting provider
# than your Express backend API (e.g., when deploying frontend on Vercel separately).
VITE_API_URL=""

# Client-side Firebase configurations (VITE_ prefixed)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# MongoDB Connection URI: Required to connect to MongoDB Atlas for storing users, research papers, etc.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/researchmind"

